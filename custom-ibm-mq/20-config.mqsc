* Define custom queues
DEFINE QLOCAL('ORDER.REQUEST') REPLACE
DEFINE QLOCAL('ORDER.RESPONSE') REPLACE

* Enable SSL on Queue Manager
ALTER QMGR SSLKEYR('/opt/mqm/ssl/key')

* Configure TLS on channel with OPTIONAL client auth
ALTER CHANNEL('DEV.ADMIN.SVRCONN') CHLTYPE(SVRCONN) +
      SSLCIPH(TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384) +
      SSLCAUTH(OPTIONAL) REPLACE

REFRESH SECURITY TYPE(SSL)
REFRESH SECURITY TYPE(AUTHSERV)
